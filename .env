# .env.example — Ye file copy karo aur .env naam do
# KABHI bhi .env file GitHub pe push mat karo!

# PostgreSQL Connection
DATABASE_URL=postgresql://postgres:123456@localhost/core_auth_db

# Redis Connection
REDIS_HOST=localhost
REDIS_PORT=6379

# JWT Secrets — strong random strings use karo
# Generate karne ke liye: python -c "import secrets; print(secrets.token_hex(32))"
ACCESS_TOKEN_SECRET=3f8a2d1e9c7b4f6a0e5d8c2b1a9f3e7d6c4b2a0f8e1d5c9b3a7f2e6d4c8b1a
REFRESH_TOKEN_SECRET=7c1e4a9f2b6d8e3c0a5f1b4e7d2c9a6f3b8e1d4c7a0f5b2e9d6c3a8f1b4e7d

# Token Expiry (optional — defaults use honge agar set nahi)
ACCESS_TOKEN_EXPIRE_MINUTES=15
REFRESH_TOKEN_EXPIRE_DAYS=7
